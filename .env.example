# COSMIC 工作流 - API 配置
# 从 n8n 工作流中使用的 OpenRouter API

# OpenRouter (n8n 里用的就是这个)
OPENAI_API_KEY=sk-or-v1-你的key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.6-27b

# 也可以用其他兼容 OpenAI API 的后端，例如：
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# LLM_MODEL=qwen3.6-27b-uncensored-hauhaucs-aggressive
